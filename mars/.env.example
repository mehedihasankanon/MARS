# ============================================================
# MARS — Environment Variables Reference
# ============================================================
# This file documents ALL env vars needed to run the project.
# Copy the relevant variables into the correct file:
#   Backend  → backend/.env
#   Frontend → frontend/.env.local
# ============================================================

# ─── Backend (backend/.env) ─────────────────────────────────
# These variables are used ONLY by the Express server.
# They must NEVER appear in frontend/.env.local.

# Server port
PORT=5001

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/mars_db

# Secret used to sign and verify JWT tokens (use a long random string)
JWT_SECRET=

# Cloudinary credentials (used server-side for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Frontend (frontend/.env.local) ─────────────────────────
# Only NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Everything else stays on the server side of Next.js.

# Base URL of the Express backend API
NEXT_PUBLIC_API_URL=http://localhost:5001/api